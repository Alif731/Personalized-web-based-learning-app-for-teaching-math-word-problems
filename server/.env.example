
PORT=5000
MONGO_URI=mongodb://localhost:27017/math_learning_system
NODE_ENV=development

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_strong_random_secret
JWT_EXPIRES_IN_DAYS=7

# Keep demo user seeding enabled in non-production by default.
# Set to false to disable seeding locally.
SEED_DEMO_USER=true

# Login limiter defaults: 10 attempts per 15 minutes
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW_MS=900000

# Register limiter defaults: 5 attempts per 60 minutes
REGISTER_RATE_LIMIT_MAX=5
REGISTER_RATE_LIMIT_WINDOW_MS=3600000

# OAuth limiter defaults: 20 attempts per 15 minutes
OAUTH_RATE_LIMIT_MAX=20
OAUTH_RATE_LIMIT_WINDOW_MS=900000
